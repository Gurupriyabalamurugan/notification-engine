# Application
APP_NAME=notification-engine
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://notification:notification@localhost:5432/notification_engine

# Redis
REDIS_URL=redis://localhost:6380/0
IDEMPOTENCY_TTL_SECONDS=86400

# Mock providers (optional overrides)
MOCK_EMAIL_FAILURE_RATE=0.0
MOCK_EMAIL_DOWN=false
MOCK_EMAIL_LATENCY_MS=0

MOCK_SMS_FAILURE_RATE=0.0
MOCK_SMS_DOWN=false
MOCK_SMS_LATENCY_MS=0

MOCK_PUSH_FAILURE_RATE=0.0
MOCK_PUSH_DOWN=false
MOCK_PUSH_LATENCY_MS=0

# Circuit breaker + retry
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_OPEN_SECONDS=60
RETRY_WORKER_POLL_SECONDS=10

# Kafka (Redpanda)
KAFKA_BOOTSTRAP_SERVERS=localhost:19092
KAFKA_CLIENT_ID=notification-engine
KAFKA_CONSUMER_GROUP=notification-dispatcher
KAFKA_TOPIC_PARTITIONS=12
